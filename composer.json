{
    "name": "crovver/crovver-php",
    "description": "Official PHP SDK for Crovver subscription management",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": ["crovver", "subscription", "billing", "saas", "payments"],
    "homepage": "https://crovver.com",
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "guzzlehttp/promises": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Crovver\\": "src/"
        },
        "classmap": [
            "src/Types/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Crovver\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
